  // CivicComputing may already be loaded (e.g. from cache) before this script ran
  if (typeof CookieControl !== 'undefined') initCookieControl();

  document.addEventListener('click', function(e) {
    if (e.target.closest('#ccc-notify-dismiss')) {
      trackConsent(window.location.pathname, 'banner', 'dismissed');
    }

    if (e.target.closest('#ccc-close')) {
      trackConsent(window.location.pathname, 'banner', 'dismissed');
    }

