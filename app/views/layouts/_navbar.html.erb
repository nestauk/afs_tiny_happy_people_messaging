<nav class="py-1 bg-bbc-blue text-white sticky" role="navigation">
  <a href="#main" class="absolute top-auto w-1 h-1 overflow-hidden focus:static focus:w-auto focus:h-auto text-bbc-yellow">Skip to main content</a>
  <div class="md:px-24 px-3 flex items-center w-full justify-between">
    <%= link_to root_url, class: "md:w-1/2 w-full flex items-center", "aria-label": "BBC logo" do %>
      <%= image_tag "horizontal-logo.png", alt: "BBC logo", class: "h-12 md:h-14" %>
    <% end %>
    <div class="hidden md:block">
      <% if current_admin %>
        <div class="flex justify-between xl:w-1/6 w-1/3">
          <%= link_to "Dashboard", dashboard_admin_users_path, class: 'text-lg' %> |
          <%= link_to "Sign out", destroy_admin_session_path, "data-turbo-method": :delete, class: 'text-lg' %>
        </div>
      </div>
    <% else %>
      <%# Show on mobile %>
      <%= link_to (I18n.locale == :en ? "Cymraeg" : "English"), url_for(params.permit!.merge(locale: I18n.locale == :en ? :cy : :en)) %>
    <% end %>
  </div>
</nav>
