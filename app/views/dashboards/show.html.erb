<h1>
  Local Authority data dashboard
</h1>

<section>
  <h2>
    For all LAs
  </h2>

  <div class="flex justify-between">
    <div class="p-5 border-2 border-purple-500 rounded text-center bg-white">
      <h3 class="text-large font-bold mb-4">Total number of sign ups</h3>
      <p class="text-4xl">
        <%= @all_las_dashboard.total_user_count %>
      </p>
    </div>

    <div class="p-5 border-2 border-purple-500 rounded text-center bg-white">
      <h3 class="text-large font-bold mb-4">Sign ups this month</h3>
      <p class="text-4xl">
        <%= @all_las_dashboard.new_users_this_month_count %>
      </p>
    </div>

    <div class="p-5 border-2 border-purple-500 rounded text-center bg-white">
      <h3 class="text-large font-bold mb-4">Sign ups this year</h3>
      <p class="text-4xl">
        <%= @all_las_dashboard.new_users_this_year_count %>
      </p>
    </div>

    <div class="p-5 border-2 border-purple-500 rounded text-center bg-white">
      <h3 class="text-large font-bold mb-4">Average click through rate</h3>
      <p class="text-4xl">
        <%= @all_las_dashboard.average_overall_clickthrough_rates.round %>%
      </p>
    </div>

    <div class="p-5 border-2 border-purple-500 rounded text-center bg-white">
      <h3 class="text-large font-bold mb-4">Average click through rates this month</h3>
      <p class="text-4xl">
        <%= @all_las_dashboard.average_this_month_clickthrough_rates.round %>%
      </p>
    </div>
  </div>
</section>

<section class="mt-10">
  <h2>Top 5 LAs with the highest sign up rate</h2>
  <ol>
    <% User.all.where.not(local_authority: nil).group_by(&:local_authority).each do |group| %>
      <li><%= group.first.name %></li>
    <% end %>
  </ol>
</section>

<section class="mt-10"  data-controller="dashboards">
  <form id="filterForm">
    <label for="category">Choose a local authority:</label>
    <select id="category" data-action="change->dashboards#toggle">
      <option value="" selected disabled>-- Local authority --</option>
      <% LocalAuthority.all.order(:name).each do |la| %>
        <option value="<%= la.name %>"><%= la.name %></option>
      <% end %>
    </select>
  </form>
  <% @specific_la_dashboards.each do |dashboard| %>
    <div id="<%= dashboard.la_name %>_dashboard" class="hidden dashboard">
      <h2 class="mt-5">
        For <%= dashboard.la_name %>
      </h2>

      <div class="flex justify-between">
        <div class="p-5 border-2 border-purple-500 rounded text-center bg-white">
          <h3 class="text-large font-bold mb-4">Total number of sign ups</h3>
          <p class="text-4xl">
            <%= dashboard.total_user_count %>
          </p>
        </div>

        <div class="p-5 border-2 border-purple-500 rounded text-center bg-white">
          <h3 class="text-large font-bold mb-4">Sign ups this month</h3>
          <p class="text-4xl">
            <%= dashboard.new_users_this_month_count %>
          </p>
        </div>

        <div class="p-5 border-2 border-purple-500 rounded text-center bg-white">
          <h3 class="text-large font-bold mb-4">Sign ups this year</h3>
          <p class="text-4xl">
            <%= dashboard.new_users_this_year_count %>
          </p>
        </div>

        <div class="p-5 border-2 border-purple-500 rounded text-center bg-white">
          <h3 class="text-large font-bold mb-4">Average click through rate</h3>
          <p class="text-4xl">
            <%= dashboard.average_overall_clickthrough_rates %>%
          </p>
        </div>

        <div class="p-5 border-2 border-purple-500 rounded text-center bg-white">
          <h3 class="text-large font-bold mb-4">Average click through rates this month</h3>
          <p class="text-4xl">
            <%= dashboard.average_this_month_clickthrough_rates %>%
          </p>
        </div>
      </div>
    </div>
  <% end %>
</section>
