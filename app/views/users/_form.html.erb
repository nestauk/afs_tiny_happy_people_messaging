<div class="md:mt-8 w-full">
  <%= turbo_frame_tag "form" do %>
    <%= simple_form_for @user, anchor: "sign-up-form"  do |form| %>
      <% if notice %>
        <p class="border border-blue-500 bg-blue-50 text-blue-900 p-3 mb-8">
          <%= notice %>
        </p>
      <% end %>

      <%= form.input :phone_number, wrapper_html: { class: "w-full" }, input_html: { class: "md:w-1/3", autocomplete: "tel" } %>

      <fieldset class="mt-3 <%= 'input_wrapper field_with_errors' if @user.errors[:postcode].any? %>">
        <%= form.label :postcode %>
        <p class="hint"><%= t("simple_form.hints.user.postcode") %></p>
        <% if @user.errors[:postcode].any? %>
          <% @user.errors[:postcode].each do |error| %>
            <p class="text-red-600 text-sm">
              <%= error.capitalize.html_safe %>
            </p>
          <% end %>
        <% end %>
        <%= form.text_field :postcode, class: "md:w-1/3", autocomplete: "postal-code" %>
      </fieldset>

      <fieldset class="mt-3 <%= 'input_wrapper field_with_errors' if @user.errors[:child_birthday].any? %>">
        <legend>* <%= t("simple_form.labels.user.child_birthday") %></legend>
        <p class="hint"><%= t("simple_form.hints.user.child_birthday") %></p>
        <% if @user.errors[:child_birthday].any? %>
          <% @user.errors.where(:child_birthday).each do |error| %>
            <% next if error.type == :too_young %>
            <p class="text-red-600 text-sm">
              <%= error.message.html_safe %>
            </p>
          <% end %>
          <% if @user.errors.of_kind?(:child_birthday, :too_young) %>
            <%= form.hidden_field :skip_age_validation, value: true %>
            <div class="border-2 border-red-600 p-4 my-2">
              <p class="text-red-600 text-base">
                <%= t("activerecord.errors.models.user.attributes.child_birthday.too_young").gsub("{{waitlist_link}}", "<input type='submit' value='#{t("pages.home.waitlist")}' name='commit'>").html_safe %>
              </p>
            </div>
          <% end %>
        <% end %>
        <div class="flex gap-1 align-middle">
          <input type="hidden" id="user_child_birthday_3i" name="user[child_birthday(3i)]" value="1" autocomplete="off">
          <div>
            <select id="user_child_birthday_2i" name="user[child_birthday(2i)]" aria-label="Month">
              <% (1..12).each do |m| %>
                <option value="<%= m %>" <%= 'selected' if m == @user.child_birthday&.month %>><%= I18n.t("simple_form.options.user.month.#{Date::MONTHNAMES[m].downcase}") %></option>
              <% end %>
            </select>
          </div>
          <div>
            <select id="user_child_birthday_1i" name="user[child_birthday(1i)]" aria-label="Year">
              <% (DateTime.current.year - 2..DateTime.current.year).each do |y| %>
                <option value="<%= y %>" <%= 'selected' if y == @user.child_birthday&.year %>><%= y %></option>
              <% end %>
            </select>
          </div>
        </div>
      </fieldset>

      <%= form.input :terms_agreed, as: :boolean, label: false, inline_label: t('simple_form.labels.user.terms_agreed_at', terms: (link_to(t('pages.home.terms'), terms_path, class: 'underline hover:no-underline', target: '_blank')), privacy: (link_to(t('pages.home.privacy'), privacy_policy_path, class: 'underline hover:no-underline', target: '_blank'))).html_safe, input_html: { class: "form-checkbox focus:!ring-2 focus:!ring-blue-500" }, wrapper_html: { class: "mt-4 mb-2 md:mt-8 text-xs md:text-base" }  %>

      <%= form.input :language, as: :hidden, input_html: { value: params[:locale] || I18n.default_locale } %>

      <%= form.submit I18n.t("pages.home.submit"), class: "btn btn-primary mt-2 bg-bbc-dark-blue text-white w-full", "data-turbolinks": "false" %>
    <% end %>
  <% end %>
  <div class="hidden text-red-600"></div>
</div>
