<div class="md:mt-8 w-full">
  <%= turbo_frame_tag "form" do %>
    <%= simple_form_for @user, anchor: "sign-up-form"  do |form| %>
      <% if notice %>
        <p class="border border-blue-500 bg-blue-50 text-blue-900 p-3 mb-8">
          <%= notice %>
        </p>
      <% end %>

      <div class="w-full flex flex-col mb-5">
        <%= form.label :phone_number, required: true %>
        <p class="hint"><%= t("simple_form.hints.user.phone_number") %></p>
        <% if @user.errors[:phone_number].any? %>
          <% @user.errors[:phone_number].each do |error| %>
            <p class="text-red-600 text-sm" id="phone-number-error" role="alert">
              <%= error.capitalize.html_safe %>
            </p>
          <% end %>
        <% end %>
        <%= form.text_field :phone_number, class: "md:w-1/3 #{@user.errors[:phone_number].any? ? '!border-red-600' : ''}", autocomplete: "tel", required: true, aria: { describedby: "phone-number-error" } %>
      </div>

      <div class="w-full flex flex-col mb-5">
        <%= form.label :postcode, required: true %>
        <p class="hint"><%= t("simple_form.hints.user.postcode") %></p>
        <% if @user.errors[:postcode].any? %>
          <% @user.errors[:postcode].each do |error| %>
            <p class="text-red-600 text-sm" id="postcode-error" role="alert">
              <%= error.capitalize.html_safe %>
            </p>
          <% end %>
        <% end %>
        <%= form.text_field :postcode, class: "md:w-1/3 #{@user.errors[:postcode].any? ? '!border-red-600' : ''}", autocomplete: "postal-code", required: true, aria: { describedby: "postcode-error" } %>
      </div>

      <fieldset class="mt-3">
        <legend>* <%= t("simple_form.labels.user.child_birthday") %></legend>
        <p class="hint"><%= t("simple_form.hints.user.child_birthday") %></p>
        <% if @user.errors[:child_birthday].any? %>
          <% @user.errors.where(:child_birthday).each do |error| %>
            <% next if error.type == :too_young %>
            <p class="text-red-600 text-sm" id="child-birthday-error" role="alert">
              <%= error.message.html_safe %>
            </p>
          <% end %>
        <% end %>
        <div class="flex gap-1 align-middle">
          <input type="hidden" id="user_child_birthday_3i" name="user[child_birthday(3i)]" value="1" autocomplete="off">
          <div>
            <select id="user_child_birthday_2i" name="user[child_birthday(2i)]" aria-label="Month" required aria-describedby="child-birthday-error">
              <% (1..12).each do |m| %>
                <option value="<%= m %>" <%= 'selected' if m == @user.child_birthday&.month %>><%= I18n.t("simple_form.options.user.month.#{Date::MONTHNAMES[m].downcase}") %></option>
              <% end %>
            </select>
          </div>
          <div>
            <select id="user_child_birthday_1i" name="user[child_birthday(1i)]" aria-label="Year" required aria-describedby="child-birthday-error">
              <% (DateTime.current.year - 2..DateTime.current.year).each do |y| %>
                <option value="<%= y %>" <%= 'selected' if y == @user.child_birthday&.year %>><%= y %></option>
              <% end %>
            </select>
          </div>
        </div>
         <% if @user.errors.of_kind?(:child_birthday, :too_young) %>
            <%= form.hidden_field :skip_age_validation, value: true %>
            <p class="text-red-600 text-base mt-2" id="child-birthday-error" role="alert">
              <%= t("activerecord.errors.models.user.attributes.child_birthday.too_young").gsub("{{waitlist_link}}", "<input type='submit' value='#{t("pages.home.waitlist")}' name='commit' class='link'>").html_safe %>
            </p>
          <% end %>
      </fieldset>

      <%= form.input :language, as: :hidden, input_html: { value: params[:locale] || I18n.default_locale } %>

      <div>
        <div class="my-4">
          <a 
            @click="showSources = !showSources"
            @keyup.space="showSources = !showSources"
            @keyup.enter="showSources = !showSources"
            role="button"
            class="no-underline text-black cursor-pointer focus:ring-2 focus:ring-blue-500"
            tabindex="0"
          >
            <span  class="flex items-center gap-1">
              <span x-show="!showSources" class="material-symbols-sharp" aria-hidden="true">keyboard_arrow_down</span>
              <span x-show="showSources" class="material-symbols-sharp" aria-hidden="true">keyboard_arrow_up</span>
              <%= t("pages.home.what_to_expect") %>
            </span>
          </a>
        </div>
        <div x-show="showSources" class="mt-4"><%= t("pages.home.free").html_safe %></div>
      </div>

      <% if @user.errors[:terms_agreed].any? %>
        <% @user.errors.where(:terms_agreed).each do |error| %>
          <p class="text-red-600 text-sm" id="terms-agreed-error" role="alert">
            <%= error.message.html_safe %>
          </p>
        <% end %>
      <% end %>
      <%= form.label :terms_agreed, class: "flex items-center gap-1 text-sm md:text-base", required: true, "aria-describedby": "terms-agreed-error" do %>
        <%= form.check_box :terms_agreed, class: "form-checkbox focus:!ring-2 focus:!ring-blue-500 !grow-0" %>
        <div>
          <%= t('simple_form.labels.user.terms_agreed_at', terms: (link_to(t('pages.home.terms'), terms_path, class: 'underline hover:no-underline', target: '_blank')), privacy: (link_to(t('pages.home.privacy'), privacy_policy_path, class: 'underline hover:no-underline', target: '_blank'))).html_safe %>
        </div>
      <% end %>

      <%= hidden_field_tag "user_referrer[utm_source]", params[:utm_source] %>
      <%= hidden_field_tag "user_referrer[utm_medium]", params[:utm_medium] %>
      <%= hidden_field_tag "user_referrer[utm_campaign]", params[:utm_campaign] %>
      <%= hidden_field_tag "user_referrer[utm_term]", params[:utm_term] %>
      <%= hidden_field_tag "user_referrer[utm_content]", params[:utm_content] %>
      <%= hidden_field_tag "user_referrer[gclid]", params[:gclid] %>

      <%= form.submit I18n.t("pages.home.submit"), class: "btn btn-primary mt-2 w-full", "data-turbolinks": "false" %>
    <% end %>
  <% end %>
  <div class="hidden text-red-600"></div>
</div>
