<% content_for(:page_title) { "How did you find out about us?" } %>

<div class="bg-bbc-dark-blue p-5 md:p-10 mx-2">
  <h1 class="text-4xl text-bbc-yellow">
    You're almost done
  </h1>

  <h2 class="font-normal text-lg text-white">
    Tell us how you found out about our service, and what you are interested in
  </h2>

  <%= f.button :submit, "Skip this section", class: 'link text-white', data: { turbo_submits_with: 'Skipping...' } %>
</div>

<div class="mt-8 w-full px-5">
  <%= f.input :referral_sources, required: false, label: "Where have you seen this service advertised?", hint: "Knowing how you heard about us helps us understand which channels are best and where to focus our efforts", as: :check_boxes, collection: ["Facebook", "Instagram", "Referral by a professional", "Flyer/Poster", "Email", "Other"] %>

  <div class="mt-5 flex flex-col gap-2">
    <%= f.button :submit, "Next", class: 'btn bg-bbc-dark-blue text-white', data: { turbo_submits_with: 'Saving...' } %>
    <%= link_to "Back", edit_user_path(@user, token: params[:token], step: "personalisation"), class: 'btn bg-blue-200 text-black' %>
  </div>
</div>
