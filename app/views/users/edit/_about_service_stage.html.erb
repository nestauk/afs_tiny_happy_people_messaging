<% content_for(:page_title) { I18n.t("pages.form.about_service.page_title") } %>

<div class="bg-bbc-dark-blue p-5 md:p-10 mx-2">
  <h1 class="text-4xl text-bbc-yellow">
    <%= t("pages.form.about_service.title") %>
  </h1>

  <h2 class="font-normal text-lg text-white">
    <%= t("pages.form.about_service.blurb") %>
  </h2>

  <%= f.button :submit, t("pages.form.about_service.skip"), class: 'link text-white !p-0 shadow-none', data: { turbo_submits_with: 'Skipping...' } %>
</div>

<div class="mt-8 w-full px-5">
  <%=
    f.input :referral_sources,
    required: false,
    as: :check_boxes,
    collection: [[:facebook, "Facebook"], [:instagram, "Instagram"], [:professional, "Referral by a professional"], [:flyer, "Flyer/Poster"], [:email, "Email"], [:other, "Other"]],
    label_method: lambda { |el| t "simple_form.options.user.referral_sources.#{el.first}" }
  %>

  <div class="mt-5 flex flex-col gap-2">
    <%= f.button :submit, t("pages.form.about_service.save"), class: 'btn btn-primary mt-2 bg-bbc-dark-blue text-white w-full', data: { turbo_submits_with: t("pages.form.about_service.saving") } %>
    <%= link_to t("pages.form.about_service.back"), edit_user_path(@user, token: params[:token], step: "personalisation"), class: 'btn bg-blue-200 text-black' %>
  </div>
</div>
