    </div>
    <div class="bg-orange-100 p-8 col-span-1">
      <h2>📈 <%= t('pages.resources.england.development.title') %></h2>
      <ul>
        <li class="mb-4">
          <%= t('pages.resources.england.development.para1').html_safe %>
        </li>
        <li class="mb-4">
          <%= t('pages.resources.england.development.para2').html_safe %>
