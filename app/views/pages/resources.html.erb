        </li>
        <li class="mb-4">
          <%= t('pages.resources.england.emergency.para3').html_safe %>
        </li>
        <li class="mb-4">
          <%= t('pages.resources.england.emergency.para4').html_safe %>
        </li>
      </ul>
    </div>
  </div>
</div>

