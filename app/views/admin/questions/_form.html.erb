<%= form_with(model: [@survey, @question], local: true, url: (@question.persisted? ? admin_survey_question_path(@survey, @question) : admin_survey_questions_path(@survey))) do |form| %>
  <%= form.hidden_field :position, value: @question.position || @survey.questions.count + 1 %>

  <div class="mb-4">
    <%= form.label :text, class: "block text-sm font-medium text-gray-700" %>
    <%= form.text_area :text, class: "mt-1 block w-full border border-gray-300 rounded-md shadow-sm focus:ring focus:ring-blue-500" %>
  </div>

  <div class="mb-4">
    <%= form.label :question_type, class: "block text-sm font-medium text-gray-700" %>
    <%= form.select :question_type, options_for_select([["Text", "text"], ["Check boxes", "check_boxes"], ["Radio buttons", "radio_buttons"]]), {}, class: "mt-1 block w-full border border-gray-300 rounded-md shadow-sm focus:ring focus:ring-blue-500" %>
  </div>

  <div class="mb-4">
    <%= form.label :options_text, "Options (one per line)", class: "block text-sm font-medium text-gray-700" %>
    <%= form.text_area :options_text, value: @question.options.join("\n"), class: "mt-1 block w-full border border-gray-300 rounded-md shadow-sm focus:ring focus:ring-blue-500" %>
  </div>

  <div class="mb-4">
    <%= form.submit "Create question", class: "bg-blue-500 text-white rounded p-2" %>
  </div>
<% end %>
