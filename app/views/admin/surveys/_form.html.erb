<%= form_with(model: [:admin, @survey], local: true) do |form| %>
  <div class="mb-4">
    <%= form.label :title, class: "block text-sm font-medium text-gray-700" %>
    <%= form.text_field :title, class: "mt-1 block w-full border border-gray-300 rounded-md shadow-sm focus:ring focus:ring-blue-500" %>
  </div>

  <div class="mb-4">
    <%= form.label :send_after_message_count, "Send after N programme messages (0 = on signup, blank = don't auto-send)", class: "block text-sm font-medium text-gray-700" %>
    <%= form.number_field :send_after_message_count, min: 0, class: "mt-1 block w-1/2 border border-gray-300 rounded-md shadow-sm focus:ring focus:ring-blue-500" %>
  </div>

  <div class="mb-4">
    <%= form.check_box :send_on_last_message, class: "rounded border-gray-300" %>
    <%= form.label :send_on_last_message, "Send when user reaches the end of the programme", class: "text-lg font-medium text-gray-700" %>
  </div>

  <div class="mb-4">
    <%= form.submit @survey.new_record? ? "Create survey" : "Update survey", class: "bg-blue-500 text-white rounded p-2" %>
  </div>
<% end %>
