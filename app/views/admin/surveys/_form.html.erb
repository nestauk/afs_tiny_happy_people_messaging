<%= form_with(model: [:admin, @survey], local: true) do |form| %>
  <div class="mb-4">
    <%= form.label :title_en, "Title in English", class: "block text-sm font-medium text-gray-700" %>
    <%= form.text_field :title_en, class: "mt-1 block w-full border border-gray-300 rounded-md shadow-sm focus:ring focus:ring-blue-500" %>
  </div>

  <div class="mb-4">
    <%= form.label :title_cy, "Title in Welsh", class: "block text-sm font-medium text-gray-700" %>
    <%= form.text_field :title_cy, class: "mt-1 block w-full border border-gray-300 rounded-md shadow-sm focus:ring focus:ring-blue-500" %>
  </div>

  <div class="mb-4">
    <%= form.label :intro_en, "Introduction in English", class: "block text-sm font-medium text-gray-700" %>
    <%= form.rich_text_area :intro_en %>
  </div>

  <div class="mb-4">
    <%= form.label :intro_cy, "Introduction in Welsh", class: "block text-sm font-medium text-gray-700" %>
    <%= form.rich_text_area :intro_cy %>
  </div>

  <div class="mb-4">
    <%= form.label :thank_you_title_en, "Thank you page title in English", class: "block text-sm font-medium text-gray-700" %>
    <%= form.text_field :thank_you_title_en, class: "mt-1 block w-full border border-gray-300 rounded-md shadow-sm focus:ring focus:ring-blue-500" %>
  </div>

  <div class="mb-4">
    <%= form.label :thank_you_title_cy, "Thank you page title in Welsh", class: "block text-sm font-medium text-gray-700" %>
    <%= form.text_field :thank_you_title_cy, class: "mt-1 block w-full border border-gray-300 rounded-md shadow-sm focus:ring focus:ring-blue-500" %>
  </div>

  <div class="mb-4">
    <%= form.label :thank_you_body_en, "Thank you page body in English", class: "block text-sm font-medium text-gray-700" %>
    <%= form.rich_text_area :thank_you_body_en %>
  </div>

  <div class="mb-4">
    <%= form.label :thank_you_body_cy, "Thank you page body in Welsh", class: "block text-sm font-medium text-gray-700" %>
    <%= form.rich_text_area :thank_you_body_cy %>
  </div>

  <div class="mb-4">
    <%= form.label :send_after_message_count, "Send after N programme messages (0 = on signup, blank = don't auto-send)", class: "block text-sm font-medium text-gray-700" %>
    <%= form.number_field :send_after_message_count, min: 0, class: "mt-1 block w-1/2 border border-gray-300 rounded-md shadow-sm focus:ring focus:ring-blue-500" %>
  </div>

  <div class="mb-4">
    <%= form.submit @survey.new_record? ? "Create survey" : "Update survey", class: "bg-blue-500 text-white rounded p-2" %>
  </div>
<% end %>
