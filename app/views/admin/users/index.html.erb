<div data-controller="users">
  <h1 class="text-4xl">
    Users (<%= @users.count %>)
  </h1>
  <p>Filters</p>
  <%= form_with url: admin_users_path, method: :get, local: true, class: "mb-4" do %>
    <div class="flex flex-row mb-2 gap-4">
      <div class="flex w-1/3">
        <%= text_field_tag :phone_number, params[:phone_number], placeholder: "Search by phone number", class: "border border-gray-300 rounded p-1" %>
      </div>
      <div class="flex">
        <label class="inline-flex items-center">
          <%= check_box_tag :opted_out, "true", params[:opted_out].present?, class: "form-checkbox" %>
          <span class="ml-1">Opted out users</span>
        </label>
      </div>
      <div class="flex">
        <label class="inline-flex items-center">
          <%= check_box_tag :finished, "true", params[:finished].present?, class: "form-checkbox" %>
          <span class="ml-1">Finished users</span>
        </label>
      </div>
    </div>
    <div class="flex flex-row mb-4 gap-4 items-center">
      <%= submit_tag "Search", class: "bg-bbc-blue text-white rounded p-2 w-1/5" %>
      <%= link_to "Clear filters", admin_users_path, class: "link" %>
    </div>
  <% end %>
  <table class="table-auto w-full">
    <thead>
      <tr class="bg-blue-300 text-left">
        <th class="px-4 py-4">Phone number</th>
        <th class="px-4 py-4">Name</th>
        <th class="px-4 py-4">Child's current age</th>
      </tr>
    </thead>
    <tbody>
      <% @current_users.order(:first_name).each do |user| %>
        <tr class="border-b-2">
          <td class="px-4 py-4 bg-white">
            <%= link_to user.phone_number, admin_user_path(user), class: "underline hover:no-underline" %>
          </td>
          <td class="px-4 py-4 bg-white">
            <%= user.first_name %>
          </td>
          <td class="px-4 py-4 bg-white">
            <%= user.child_age_in_months_today %> months
          </td>
        </tr>
      <% end %>
    </tbody>
  </table>
  <div class="text-center mt-10 text-lg">
    <%= paginate @current_users, remote:true %>
  </div>
</div>
