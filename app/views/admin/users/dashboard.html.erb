<h1 class="text-4xl">Messages received</h1>
<table class="table-auto w-full mt-8">
  <thead>
    <tr class="bg-blue-300 text-left">
      <th class="px-4 py-4">Name</th>
      <th class="px-4 py-4">Message</th>
      <th class="px-4 py-4">Received</th>
      <td>
        &nbsp;
      </td>
    </tr>
  </thead>
  <tbody>
    <% @messages.includes([:user]).order(:created_at).each do |message| %>
      <tr class="border-b-2">
        <td class="px-4 py-4 bg-white">
          <%= link_to "#{message.user.first_name} #{message.user.last_name}", admin_user_path(message.user), class: "underline hover:no-underline" %>
        </td>
        <td class="px-4 py-4 bg-white">
          <%= message.body %>
        </td>
        <td class="px-4 py-4 bg-white">
          <%= message.created_at.strftime("%d/%m/%y") %>
        </td>
        <td class="px-4 py-4 bg-white flex gap-2 justify-end">
          <%= simple_form_for message, url: admin_user_message_path(user_id: message.user, id: message.id), html: { class: "inline w-fit" } do |f| %>
            <%= hidden_field_tag 'seen', 'true'  %>
            <%= f.submit "Mark as seen", class: "link w-fit" %>
          <% end %>
          <%= link_to "Reply", new_admin_user_message_path(message.user), class: "underline hover:no-underline" %>
        </td>
      </tr>
    <% end %>
  </tbody>
</table>
